        curTime = localDate.getUTCHours() + localDate.getUTCMinutes() / 60 + localDate.getUTCSeconds() / 3600;
    }

    // Julian date for the current instant (UT)
    let JD = JD0 + (curTime - ST) / 24;

    // ============================================================
    // STEP 2: COMPUTE GHA ARIES
    // ============================================================
    // Get GHA Aries from sunData (since getAlmanacSun gives it)
    let sunData = getAlmanacSun(JD, dt, 0, 0);
    let ghaAries = sunData.ghaArise;

    // Recompute for steps using fundamental formulas
    RunAlmanacCalculations(JD, dt);
    Nutation(); // ensures delta_psi, eps are set

    // 2.1 Compute time since J2000.0 in days and centuries
    let daysSinceJ2000 = JD - 2451545.0; // days from J2000.0
    let T = daysSinceJ2000 / 36525.0;    // centuries from J2000.0

    // 2.2 Compute GMST (Greenwich Mean Sidereal Time)
    let GMST = 280.46061837 + 360.98564736629 * daysSinceJ2000 + 0.000387933 * T * T - T * T * T / 38710000;
    GMST = ((GMST % 360) + 360) % 360; // normalize to 0-360

    // 2.3 Compute Equation of Equinoxes
    let eq_eq = delta_psi * cosd(eps); // delta_psi in degrees, eps in degrees

    // 2.4 GAST = GMST + Equation of Equinoxes
    let GAST = (GMST + eq_eq) % 360;

    // 2.5 GHA Aries = GAST (by definition)
    let ghaAries_calc = GAST;

    // ============================================================
    // STEP 3: GENERATE HTML OUTPUT WITH DETAILS
    // ============================================================
    return `
        <p><span class="formula">GHA Aries (Greenwich Hour Angle of Aries)</span></p>

        <p>GHA Aries is the Greenwich Hour Angle of the vernal equinox, equal to Greenwich Apparent Sidereal Time (GAST). It is used as a reference for converting right ascension to hour angle.</p>

