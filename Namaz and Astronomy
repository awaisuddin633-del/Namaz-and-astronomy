             <tr><td>cos(ε) = cos(${epsilon.toFixed(4)}°)</td><td>= <span class="value">${Math.cos(epsilon * dtr).toFixed(6)}</span></td></tr>
             <tr><td>sin(ε) = sin(${epsilon.toFixed(4)}°)</td><td>= <span class="value">${Math.sin(epsilon * dtr).toFixed(6)}</span></td></tr>
         </table>

        <p><strong>Now plug into the formula:</strong></p>
        <p style="margin-left:20px;">
            Numerator = sin(λ)·cos(ε) - tan(β)·sin(ε)<br>
            = ${Math.sin(lambda * dtr).toFixed(6)} × ${Math.cos(epsilon * dtr).toFixed(6)} - ${Math.tan(beta * dtr).toFixed(6)} × ${Math.sin(epsilon * dtr).toFixed(6)}<br>
            = ${(Math.sin(lambda * dtr) * Math.cos(epsilon * dtr)).toFixed(6)} - ${(Math.tan(beta * dtr) * Math.sin(epsilon * dtr)).toFixed(6)}<br>
            = <span class="value">${(Math.sin(lambda * dtr) * Math.cos(epsilon * dtr) - Math.tan(beta * dtr) * Math.sin(epsilon * dtr)).toFixed(6)}</span>
        </p>
        <p style="margin-left:20px;">
            Denominator = cos(λ) = <span class="value">${Math.cos(lambda * dtr).toFixed(6)}</span>
        </p>
        <p style="margin-left:20px;">
            RA (radians) = atan2( Numerator , Denominator ) = <span class="value">${Math.atan2(numerator, denominator).toFixed(6)} rad</span>
