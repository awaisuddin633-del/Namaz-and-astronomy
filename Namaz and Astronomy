function getEOTSunAlgoSteps() {
    let { C5, D5, E5, F11, F13, ST } = readInputs();
    let date = new Date(Date.UTC(E5, D5-1, C5, 0,0,0));
    let JD0 = getJD0(date);
    let dt = getDeltaT(E5);
    
    // Get current time
