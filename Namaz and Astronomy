    if (Math.abs(cosH2) > 1) cosH2 = Math.sign(cosH2) * 0.9999;
    let H2_deg = acos(cosH2) * (180/PI);
    let H2_hours = H2_deg / 15;
    let t3 = 12 + ST - F13/15 - eot2 + H2_hours;
    
