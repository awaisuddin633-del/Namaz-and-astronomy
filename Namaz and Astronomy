        function findCurrentAndNext(prayerTimes, currentLocalHours) {
            let times = [
                { name: 'Fajar', time: prayerTimes.fajr },
                { name: 'Sunrise', time: prayerTimes.sunrise },
                { name: 'Dahwa e Kubra', time: prayerTimes.dhuha },
                { name: 'Zuhar', time: prayerTimes.zuhr },
                { name: 'Asar', time: prayerTimes.asr },
                { name: 'Maghrib', time: prayerTimes.maghrib },
                { name: 'Isha', time: prayerTimes.isha }
            ];
            let ishaTime = times[6].time;
            let fajrNextDay = times[0].time + 24;
            times.push({ name: 'Fajar (next)', time: fajrNextDay });
            
            let current = null;
            let next = null;
            let now = currentLocalHours;
            for (let i = 0; i < times.length - 1; i++) {
                if (now >= times[i].time && now < times[i+1].time) {
                    current = times[i];
                    next = times[i+1];
                    break;
                }
            }
            if (!current) {
                if (now >= ishaTime) {
                    current = times[6];
                    next = times[7];
                } else {
                    current = { name: 'Isha', time: ishaTime - 24 };
                    next = times[0];
                }
            }
            return { current, next };
        }

