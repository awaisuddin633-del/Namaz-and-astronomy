                const padding = maxBorder + 50;
                
                const newWidth = canvas.width + padding * 2;
                const newHeight = canvas.height + padding * 2;
                const newCanvas = document.createElement('canvas');
                newCanvas.width = newWidth;
                newCanvas.height = newHeight;
                const ctx = newCanvas.getContext('2d');
                
                ctx.fillStyle = '#ffffff';
                ctx.fillRect(0, 0, newWidth, newHeight);
                ctx.drawImage(canvas, padding, padding);
                
                container.style.overflowX = originalOverflow;
                return newCanvas;
            }).catch(() => {
                container.style.overflowX = originalOverflow;
                return null;
            })
        );
    });

    Promise.all(capturePromises).then(canvases => {
        const validCanvases = canvases.filter(c => c !== null);
        if (validCanvases.length === 0) return;
        
        const firstCanvas = validCanvases[0];
        const pdf = new jsPDF({
            orientation: firstCanvas.width > firstCanvas.height ? 'l' : 'p',
            unit: 'px',
            format: [firstCanvas.width, firstCanvas.height]
        });

        validCanvases.forEach((canvas, index) => {
            if (index > 0) {
                pdf.addPage([canvas.width, canvas.height], canvas.width > canvas.height ? 'l' : 'p');
            }
            const imgData = canvas.toDataURL('image/png');
            pdf.addImage(imgData, 'PNG', 0, 0, canvas.width, canvas.height);
        });
        
        pdf.save('all-namaz-calendars.pdf');
        containers.forEach(container => {
            container.querySelectorAll('.month-download').forEach(el => el.style.display = 'block');
        });
    }).catch(() => {
        containers.forEach(container => {
            container.querySelectorAll('.month-download').forEach(el => el.style.display = 'block');
        });
    });
}

        // ========== نئے درست قبلہ فارمولے ==========
        const KAABA_LAT = 21.42085;
        const KAABA_LON = 39.82687;

        function qiblaBearing(lat, lon) {
            let Δλ = (KAABA_LON - lon) * dtr;
            let φ1 = lat * dtr;
            let φ2 = KAABA_LAT * dtr;
            let y = Math.sin(Δλ) * Math.cos(φ2);
            let x = Math.cos(φ1) * Math.sin(φ2) - Math.sin(φ1) * Math.cos(φ2) * Math.cos(Δλ);
            let bearing = Math.atan2(y, x) * (180 / Math.PI);
            return (bearing + 360) % 360;
        }

        function qiblaDistance(lat, lon) {
            let term = sind(lat) * sind(KAABA_LAT) + cosd(lat) * cosd(KAABA_LAT) * cosd(lon - KAABA_LON);
            if (term > 1) term = 1;
            if (term < -1) term = -1;
            let centralAngle = Math.acos(term) * (180 / Math.PI);
            return centralAngle * 40075.017 / 360;
        }

        function getDirectionText(angle) {
            if (angle >= 0 && angle < 90) return (angle < 45) ? "North to East" : "East to North";
            else if (angle >= 90 && angle < 180) return (angle < 135) ? "East to South" : "South to East";
            else if (angle >= 180 && angle < 270) return (angle < 225) ? "South to West" : "West to South";
            else return (angle < 315) ? "West to North" : "North to West";
        }

        // ========== Helper for Moon Rise/Set (for Qibla) ==========
        function getMoonRiseSet(date, lat, lon, tz, elev) {
            const y = date.getUTCFullYear();
            const m = date.getUTCMonth() + 1;
            const d = date.getUTCDate();
            const JD0 = 367*y - Math.floor(7*(y + Math.floor((m+9)/12))/4) + Math.floor(275*m/9) + d + 1721013.5;
            const dt = getDeltaT(y);
            let rise = NaN, set = NaN;
            let t_rise = 14, t_set = 2;
            for(let i=0; i<4; i++) {
                let jd_rise = JD0 + (t_rise - tz)/24;
                let mData_rise = getAlmanacMoon(jd_rise, dt, lat, lon);
                let eotm_rise = -(t_rise - tz) + mData_rise.gha/15 + 12;
                if(eotm_rise > 12) eotm_rise -= 24; else if(eotm_rise < -12) eotm_rise += 24;
                
                let h0_rise = 90 + 0.56916 + mData_rise.sd - mData_rise.hp + (0.01616 * Math.sqrt(elev));
                let cosH_rise = (cos(h0_rise*dtr) - sin(lat*dtr)*sin(mData_rise.dec*dtr)) / (cos(lat*dtr)*cos(mData_rise.dec*dtr));
                if(abs(cosH_rise) <= 1) {
                    let hourAngle_rise = acos(cosH_rise) * (180/PI) / 15;
                    let transit_rise = 12 + tz - lon/15 - eotm_rise;
                    t_rise = transit_rise - hourAngle_rise;
                }
                
                let jd_set = JD0 + (t_set - tz)/24;
                let mData_set = getAlmanacMoon(jd_set, dt, lat, lon);
                let eotm_set = -(t_set - tz) + mData_set.gha/15 + 12;
                if(eotm_set > 12) eotm_set -= 24; else if(eotm_set < -12) eotm_set += 24;
                
                let h0_set = 90 + 0.56916 + mData_set.sd - mData_set.hp + (0.01616 * Math.sqrt(elev));
                let cosH_set = (cos(h0_set*dtr) - sin(lat*dtr)*sin(mData_set.dec*dtr)) / (cos(lat*dtr)*cos(mData_set.dec*dtr));
                if(abs(cosH_set) <= 1) {
                    let hourAngle_set = acos(cosH_set) * (180/PI) / 15;
                    let transit_set = 12 + tz - lon/15 - eotm_set;
                    t_set = transit_set + hourAngle_set;
                }
            }
            rise = t_rise;
            set = t_set;
            // Normalize
            if (rise < 0) rise += 24; if (rise >= 24) rise -= 24;
            if (set < 0) set += 24; if (set >= 24) set -= 24;
            return { rise, set };
        }

        // ========== Qibla Direction Timing Algorithm for Sun and Moon with day offset ==========
        function calcSunQiblaTime(dateObj, lat, lon, tz, elev, A, type, dayOffset) {
            // Adjust date for offset
            let useDate = new Date(dateObj);
            if (dayOffset !== 0) {
                useDate.setUTCDate(useDate.getUTCDate() + dayOffset);
