            let R_mh = (pressure / 1010) * (283 / (273 + temp)) * 0.0167 * tand(ZA_hma - 7.31/(94.4 - ZA_hma));
            let ZA_asar = ZA_hma + R_mh + sun_zuhr.sd;
            
            let cosH = (cosd(ZA_asar) - sind(lat) * sind(sun_zuhr.dec)) / (cosd(lat) * cosd(sun_zuhr.dec));
            if (Math.abs(cosH) > 1) cosH = Math.sign(cosH) * 0.9999;
            let H = acos(cosH) * (180/PI) / 15;
            let t = 12 + tz - lon/15 - sun_zuhr.eot + H;
            
            let JD = JD0 + (t - tz) / 24;
            let sun = getSunData(JD);
            cosH = (cosd(ZA_asar) - sind(lat) * sind(sun.dec)) / (cosd(lat) * cosd(sun.dec));
            if (Math.abs(cosH) > 1) cosH = Math.sign(cosH) * 0.9999;
            H = acos(cosH) * (180/PI) / 15;
            t = 12 + tz - lon/15 - sun.eot + H;
