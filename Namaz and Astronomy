function copyCalculationText(btn) {
    const calcSteps = btn.closest('.calc-steps');
    if (!calcSteps) return;
    
    const clone = calcSteps.cloneNode(true);
    const copyBtn = clone.querySelector('.copy-btn');
    if (copyBtn) copyBtn.remove();
    
    function elementToText(el, indentLevel = 0) {
        let text = '';
        const indent = '    '.repeat(indentLevel);
        
        for (let node of el.childNodes) {
            if (node.nodeType === Node.TEXT_NODE) {
                let content = node.textContent.replace(/\s*\n\s*/g, '\n');
                if (content.trim()) {
                    text += indent + content;
                }
            } else if (node.nodeType === Node.ELEMENT_NODE) {
                const tag = node.tagName.toLowerCase();
                
                if (tag === 'h3' || tag === 'h4') {
                    text += '\n' + indent + node.textContent.trim() + '\n';
                } else if (tag === 'p') {
                    let pText = elementToText(node, 0).trim();
                    if (pText) text += '\n' + indent + pText + '\n';
                } else if (tag === 'table') {
                    let rows = node.querySelectorAll('tr');
                    let tableText = '';
                    for (let row of rows) {
                        let cells = row.querySelectorAll('td, th');
                        // Convert NodeList to array before using map
                        let rowText = Array.from(cells).map(cell => cell.textContent.trim()).join('\t');
                        if (rowText) tableText += indent + rowText + '\n';
                    }
                    text += tableText;
                } else if (tag === 'strong' || tag === 'em' || tag === 'span') {
                    text += node.textContent;
                } else {
                    text += elementToText(node, indentLevel);
                }
            }
        }
        return text;
    }
    
    let formattedText = elementToText(clone);
    formattedText = formattedText.replace(/\n\s*\n\s*\n/g, '\n\n');
    
    navigator.clipboard.writeText(formattedText).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    }).catch(err => {
        console.error('Copy failed:', err);
        btn.textContent = 'Error';
        setTimeout(() => { btn.textContent = 'Copy'; }, 2000);
    });
}
