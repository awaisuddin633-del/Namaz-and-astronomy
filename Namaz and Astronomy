        function getOffsetHoursFromTimeZone(tzName, dateObj) {
            const dt = dateObj ? new Date(dateObj.valueOf()) : new Date();
            const utcStr = dt.toLocaleString('en-US', { timeZone: 'UTC' });
            const tzStr = dt.toLocaleString('en-US', { timeZone: tzName });
            const utcDate = new Date(utcStr);
            const tzDate = new Date(tzStr);
            const offsetMs = tzDate.getTime() - utcDate.getTime();
            return offsetMs / 3600000;
        }

