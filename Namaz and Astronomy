                const localSec = localDate.getUTCSeconds();
                curTime = localHour + localMin/60 + localSec/3600;
                document.getElementById('sun-clock').innerText = format12Hour(localHour, localMin, localSec);
            }

            const F7_GMT = curTime - ST;
            const F5_JD = 367*E5 - Math.floor(7*(E5 + Math.floor((D5+9)/12))/4) + Math.floor(275*D5/9) + C5 + 1721013.5 + F7_GMT/24;
            const F14_DT = getDeltaT(E5);

                        const s = getAlmanacSun(F5_JD, F14_DT, F11, F13);
            let EOT_Instant = s.eot;

            // Azimuth calculation using Method A (cosine formula)
            let lat_rad = F11 * dtr;
            let dec_rad = s.dec * dtr;
            let alt_rad = s.alt * dtr;
            let lha_rad = s.lha * dtr;
            
            let cos_az = (Math.sin(dec_rad) - Math.sin(lat_rad) * Math.sin(alt_rad)) / (Math.cos(lat_rad) * Math.cos(alt_rad));
            if (cos_az > 1) cos_az = 1;
            if (cos_az < -1) cos_az = -1;
            
            let az_rad = Math.acos(cos_az);
            let az_calc = az_rad / dtr;
            
            // Quadrant adjustment based on LHA
            if (Math.sin(lha_rad) > 0) {
                az_calc = 360 - az_calc;
            }

            document.getElementById('out-ra').innerText = formatDMS(s.ra);
