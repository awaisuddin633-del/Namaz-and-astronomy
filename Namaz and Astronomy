    function fmt(num, decimals = 4) { return num.toFixed(decimals); }
    function fmt6(num) { return num.toFixed(6); }
    
    let dip = (58.2 / 3600) * Math.sqrt(elev);
    const REFRACTION = 34/60 + 9/3600; // 34 minutes + 9.36 seconds in degrees
    
    // Step 1: initial at noon
    let sun0 = getSunDataAtJD(JD0, E5);
    let zenith0 = 90 + REFRACTION + sun0.sd - sun0.hp + dip;
    let dec0 = sun0.dec;
    let eot0 = sun0.eot;
    
    // Step 2: compute hour angle H0
    let cosH0 = (cosd(zenith0) - sind(F11) * sind(dec0)) / (cosd(F11) * cosd(dec0));
    if (Math.abs(cosH0) > 1) cosH0 = Math.sign(cosH0) * 0.9999;
    let H0_deg = acos(cosH0) * (180/PI);
    let H0_hours = H0_deg / 15;
    
    // Step 3: first estimate t1
