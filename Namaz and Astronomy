        function formatDMS(deg) {
            if(isNaN(deg) || Math.abs(deg) < 0.000001) return "00°00'00.000\"";
            let ab = abs(deg);
            let d = Math.floor(ab);
            let m = Math.floor((ab - d) * 60);
            let s = ((ab - d) * 60 - m) * 60;
            return `${deg < 0 ? '-' : ''}${d}°${String(m).padStart(2,'0')}'${s.toFixed(3).padStart(6,'0')}"`;
        }
        function formatTimePrecise(h) {
            if(isNaN(h)) return "--:--:--";
            let ab = abs(h);
            let H = Math.floor(ab);
            let M = Math.floor((ab - H) * 60);
            let S = (ab - H) * 3600 - M * 60;
            return `${h < 0 ? '-' : ''}${String(H).padStart(2,'0')}:${String(M).padStart(2,'0')}:${S.toFixed(3).padStart(6,'0')}`;
        }
        function formatTimeAMPM(h) {
            if(isNaN(h)) return "--:--:--";
            let H = Math.floor(h) % 24;
            let M = Math.floor((h - Math.floor(h)) * 60);
            let S = Math.round(((h - Math.floor(h)) * 60 - M) * 60);
            if(S >= 60) { M++; S = 0; } if(M >= 60) { H++; M = 0; }
            let ampm = H >= 12 ? "PM" : "AM";
            let h12 = H % 12 || 12;
            return `${h12}:${String(M).padStart(2,'0')}:${String(S).padStart(2,'0')} ${ampm}`;
        }

        // نماز کے اوقات کے الگورتھم – مکمل طور پر تبدیل (Iterative)
        function getSunData(jd) {
            const dt = getDeltaT(new Date(jdToDate(jd).getUTCFullYear()));
            const data = getAlmanacSun(jd, dt, 0, 0);
            return {
                dec: data.dec,          // deg
                eot: data.eot,          // hours
                sd: data.sd,            // deg
                hp: data.hp,             // deg
                alt: data.alt
            };
        }

        function getMoonData(jd, tz) {
            const dt = getDeltaT(new Date(jdToDate(jd).getUTCFullYear()));
            const data = getAlmanacMoon(jd, dt, 0, 0);
            let localHour = ((jd - 0.5) % 1) * 24;
            if (localHour < 0) localHour += 24;
            let eotm = -localHour + data.gha/15 + 12;
            if (eotm > 12) eotm -= 24;
            if (eotm < -12) eotm += 24;
            return { dec: data.dec, eotm: eotm, alt: data.alt };
        }

        function getJD0(date) {
            return jdFromUTCDate(date.getUTCFullYear(), date.getUTCMonth() + 1, date.getUTCDate(), 0, 0, 0);
        }

        function computeZuhrTime(date, lat, lon, tz) {
            let JD0 = getJD0(date);
            let sun0 = getSunData(JD0);
            let t = 12 + tz - lon/15 - sun0.eot;
            let JD = JD0 + (t - tz) / 24;
            let sun = getSunData(JD);
            t = 12 + tz - lon/15 - sun.eot;
            JD = JD0 + (t - tz) / 24;
            sun = getSunData(JD);
            t = 12 + tz - lon/15 - sun.eot;
            return t;
        }

        function computeFajrTime(date, lat, lon, tz, elev, angle = 108) {
            let JD0 = getJD0(date);
            let sun0 = getSunData(JD0);
            let cosH = (cosd(angle) - sind(lat) * sind(sun0.dec)) / (cosd(lat) * cosd(sun0.dec));
            if (Math.abs(cosH) > 1) cosH = Math.sign(cosH) * 0.9999;
            let H = acos(cosH) * (180/PI) / 15;
            let t = 12 + tz - lon/15 - sun0.eot - H;
            let JD = JD0 + (t - tz) / 24;
            let sun = getSunData(JD);
            cosH = (cosd(angle) - sind(lat) * sind(sun.dec)) / (cosd(lat) * cosd(sun.dec));
            if (Math.abs(cosH) > 1) cosH = Math.sign(cosH) * 0.9999;
            H = acos(cosH) * (180/PI) / 15;
            t = 12 + tz - lon/15 - sun.eot - H;
            JD = JD0 + (t - tz) / 24;
            sun = getSunData(JD);
            cosH = (cosd(angle) - sind(lat) * sind(sun.dec)) / (cosd(lat) * cosd(sun.dec));
            if (Math.abs(cosH) > 1) cosH = Math.sign(cosH) * 0.9999;
            H = acos(cosH) * (180/PI) / 15;
            t = 12 + tz - lon/15 - sun.eot - H;
            return t;
        }

        function computeSunriseTime(date, lat, lon, tz, elev) {
            let JD0 = getJD0(date);
            let dip = (58.2 / 3600) * Math.sqrt(elev);
            let sun0 = getSunData(JD0);
            let zenith = 90 + (34/60 + 9/3600) + sun0.sd - sun0.hp + dip;
            let cosH = (cosd(zenith) - sind(lat) * sind(sun0.dec)) / (cosd(lat) * cosd(sun0.dec));
            if (Math.abs(cosH) > 1) cosH = Math.sign(cosH) * 0.9999;
            let H = acos(cosH) * (180/PI) / 15;
            let t = 12 + tz - lon/15 - sun0.eot - H;
            let JD = JD0 + (t - tz) / 24;
            let sun = getSunData(JD);
            zenith = 90 + (34/60 + 9/3600) + sun.sd - sun.hp + dip;
            cosH = (cosd(zenith) - sind(lat) * sind(sun.dec)) / (cosd(lat) * cosd(sun.dec));
            if (Math.abs(cosH) > 1) cosH = Math.sign(cosH) * 0.9999;
            H = acos(cosH) * (180/PI) / 15;
