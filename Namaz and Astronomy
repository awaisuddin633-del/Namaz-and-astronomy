// ریفرنس: 1 محرم 1446 = 7 جولائی 2024
// ہم اس ریفرنس کے مطابق نیو مون کے k کی شناخت کریں گے
const REF_JD_1_MUHARRAM_1446 = jdFromUTCDate(2024, 7, 7, 0, 0, 0); // 7 July 2024, 00:00 UT
// نیو مون کا k تلاش کریں جو 7 جولائی سے پہلے واقع ہوا ہو
let ref_k = null;
for (let k = 0; k < 2000; k++) {
    let jd_newmoon = meanNewMoonJDE(k);
    if (jd_newmoon > REF_JD_1_MUHARRAM_1446) {
        ref_k = k - 1;
        break;
    }
}
// اب ref_k کے مطابق نیو مون JD حاصل کریں
let ref_newmoon_JD = meanNewMoonJDE(ref_k) + newMoonCorrection(ref_k); // ٹی ٹی میں

// کسی بھی نیو مون کے لیے ماہ کا نمبر نکالنے کا فنکشن
function getIslamicMonthFromNewMoon(k) {
    const monthNames = [
        "Muharram", "Safar", "Rabi' al-Awwal", "Rabi' al-Sani",
        "Jumadi al-Awwal", "Jumadi al-Sani", "Rajab", "Sha'ban",
        "Ramadan", "Shawwal", "Dhu al-Qadah", "Dhu al-Hijjah"
    ];
    let diff = k - ref_k;
    let monthIndex = diff % 12;
    if (monthIndex < 0) monthIndex += 12;
    let year = 1446 + Math.floor(diff / 12);
    return { name: monthNames[monthIndex], year: year };
}

function getFirstDayOfIslamicMonth(newMoonJD_ut, lat, lon, tz, elev) {
    const newMoonDate = jdToDate(newMoonJD_ut);
    const maghribTime = computeMaghribTime(newMoonDate, lat, lon, tz, elev);
    const maghribJD = jdFromUTCDate(newMoonDate.getUTCFullYear(), newMoonDate.getUTCMonth()+1, newMoonDate.getUTCDate(), 0, 0, 0) + maghribTime / 24;
    const dt = getDeltaT(newMoonDate.getUTCFullYear());
    const moonData = getAlmanacMoon(maghribJD, dt, lat, lon);
    const ageDays = maghribJD - newMoonJD_ut;
    const elong = Math.abs(moonData.elongation);
    const W = ageDays;
    const ARCV = elong;
    const q = (ARCV - (11.8371 - 6.3226 * W + 0.7319 * W * W - 0.1018 * W * W * W)) / 10;
    const visible = (q >= 0.216);
    if (visible) {
        return newMoonDate;
    } else {
        const nextDay = new Date(newMoonDate);
        nextDay.setUTCDate(newMoonDate.getUTCDate() + 1);
        return nextDay;
    }
}

