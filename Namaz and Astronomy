    <title>Namaz Precision - Almanac Pro (50 Themes)</title>
    <style>
        /* ----- ROOT VARIABLES ----- */
        :root {
            --bg-body: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            --bg-glass: rgba(255, 255, 255, 0.7);
            --bg-card: rgba(255, 255, 255, 0.6);
            --border-glass: rgba(0, 0, 0, 0.12);
            --text-main: #1f2937;
            --text-muted: #64748b;
            --primary: #2563eb;
            --shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
            --blur: 12px;
            --radius: 16px;
            --font: 'Segoe UI', system-ui, sans-serif;
            --font-alt: 'Segoe UI', system-ui, sans-serif;

            --clock-font-size: 2.6rem;      
            --day-font-size: 1.1rem;        
            --date-font-size: 0.95rem;      

            --manual-box-font-size: 0.95rem; 
            --manual-box-padding: 12px;
            --manual-box-radius: 12px;
            --manual-input-width: 52px;
            --manual-input-height: 38px;
            --manual-input-font-size: 1rem;

            /* Calendar theme variables – will be overridden by theme */
            --calendar-bg: #ffffff;
            --calendar-border: #2c3e50;
            --calendar-header-bg: #2c3e50;
            --calendar-header-text: #ffffff;
            --calendar-cell-border: #bdc3c7;
            --calendar-cell-text: #2c3e50;
            --calendar-alt-row: #f8f9fa;
        }

        * {
            box-sizing: border-box;
        }

        .astro-top { text-align:center; margin-bottom:20px; display:flex; flex-direction:column; align-items:center; gap:6px; }
        .astro-top .clock { font-family: var(--font); font-size: var(--clock-font-size); color: var(--primary); font-weight: 700; text-shadow: 0 0 10px rgba(0,0,0,0.08); }
        .astro-top .gmt-clock { font-family: var(--font-alt); font-size: 0.9rem; color: var(--text-muted); margin-top: -5px; }
        .astro-top .day { color: var(--text-main); font-weight:700; font-size: var(--day-font-size); font-family: var(--font); }
        .astro-top .date { color: var(--text-muted); font-size: var(--date-font-size); text-transform: uppercase; font-family: var(--font-alt); }
        .astro-top .location-small { color: var(--text-muted); font-size: 0.82rem; opacity:0.9; border-top: 1px dashed var(--border-glass); padding-top:6px; width:100%; font-family: var(--font-alt); }

        .moon-day-label { font-size: 0.75rem; color: inherit; margin-left: 6px; vertical-align: middle; font-weight: 700; }

