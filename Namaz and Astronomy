        let hh = parseInt(document.getElementById('sun-h').value) || 0;
        let mm = parseInt(document.getElementById('sun-m').value) || 0;
        let ss = parseInt(document.getElementById('sun-s').value) || 0;
        curTime = hh + mm/60 + ss/3600;
    } else {
        let now = new Date();
        let localMs = now.getTime() + ST * 3600000;
        let localDate = new Date(localMs);
        curTime = localDate.getUTCHours() + localDate.getUTCMinutes()/60 + localDate.getUTCSeconds()/3600;
    }
    
    let JD = JD0 + (curTime - ST) / 24;
    let sunData = getAlmanacSun(JD, dt, F11, F13);
    let eot = sunData.eot; // in hours (already from getAlmanacSun)
    let gha = sunData.gha; // GHA Sun in degrees
    
    // Calculate day fraction from JD
    let dayfraction = (JD + 0.5) - Math.floor(JD + 0.5);
    let eot_minutes_calc = 4 * gha + 720 - 1440 * dayfraction;
    
    // Normalize to range [-20, 20] minutes (as in original code)
    if (eot_minutes_calc > 20) eot_minutes_calc -= 1440;
    if (eot_minutes_calc < -20) eot_minutes_calc += 1440;
    
    let eot_hours_calc = eot_minutes_calc / 60;
    
    return `
        <p><span class="formula">Equation of Time (EOT) Calculation</span></p>
        <p>The Equation of Time is the difference between apparent solar time (sundial time) and mean solar time (clock time).</p>
        <p>In this almanac, EOT is calculated using the Greenwich Hour Angle (GHA) of the Sun.</p>
        <p>Date: ${C5}/${D5}/${E5}, Time: ${curTime.toFixed(4)} h (local), JD: <span class="value">${JD.toFixed(5)}</span></p>
