        function getAlmanacSun(jd, deltaT, lat, lon) {
    RunAlmanacCalculations(jd, deltaT);
    Sun();
    let gha = GHAsun;
    let lha = norm_360_deg(gha + lon);
    let sha = 360 - RAsun;
    let latRad = lat * dtr;
    let decRad = DECsun * dtr;
    let lhaRad = lha * dtr;
    let sinAlt = sin(latRad)*sin(decRad) + cos(latRad)*cos(decRad)*cos(lhaRad);
    let altRad = asin(sinAlt);
    let alt = altRad / dtr;

    // CORRECT azimuth calculation
    let sinLHA = sin(lhaRad);
    let cosDec = cos(decRad);
    let cosLat = cos(latRad);
    let numerator = -sinLHA * cosDec * cosLat;
    let denominator = sin(decRad) - sin(latRad) * sin(altRad);
    let az_rad = atan2(numerator, denominator);
    let az_deg = az_rad * (180 / PI);
    let az = (az_deg + 360) % 360;

    return {
        dec: DECsun, ra: RAsun, ghaArise: GHAAtrue, gha: GHAsun,
        lha: lha, sha: sha, alt: alt, az: az,
        dist: R_dist * 149597870.7,
