            document.getElementById('out-dt').innerText = F14_DT.toFixed(2);
            document.getElementById('out-eot').innerText = formatTimePrecise(EOT_Instant);

            const solve = (type) => {
                let t = type === 'rise' ? 6 : (type === 'set' ? 18 : 12);
                let dipDeg = (58.2/3600)*Math.sqrt(elev);
                for(let i=0; i<3; i++) {
                    let jd_i = (367*E5 - Math.floor(7*(E5 + Math.floor((D5+9)/12))/4) + Math.floor(275*D5/9) + C5 + 1721013.5) + (t - ST)/24;
                    let data = getAlmanacSun(jd_i, F14_DT, F11, F13);
                    let currentEOT = data.eot;
                    let transit = 12 + ST - F13/15 - currentEOT;
                    if(type === 'transit') { t = transit; } else {
                        let h0 = 90 + (34/60 + 9/3600) + data.sd - data.hp + dipDeg;
                        let cosH = (cos(h0*dtr) - sin(F11*dtr)*sin(data.dec*dtr)) / (cos(F11*dtr)*cos(data.dec*dtr));
                        if(abs(cosH) > 1) return NaN;
                        let hourAngle = acos(cosH) * (180/PI) / 15;
                        t = type === 'rise' ? transit - hourAngle : transit + hourAngle;
                    }
                }
                return t;
            };
            document.getElementById('out-sunrise').innerText = formatTimeAMPM(solve('rise'));
            document.getElementById('out-sunset').innerText = formatTimeAMPM(solve('set'));
            document.getElementById('out-transit').innerText = formatTimeAMPM(solve('transit'));

            const sunZodiacs = ["Aries","Taurus","Gemini","Cancer","Leo","Virgo","Libra","Scorpio","Sagittarius","Capricorn","Aquarius","Pisces"];
            let sunZIndex = Math.floor(lambdaSun / 30) % 12;
            document.getElementById('out-sun-zodiac').innerText = sunZodiacs[sunZIndex];
        }

        function calculateMoon() {
    const { C5, D5, E5, F11, F13, ST, elev, pressure, temp } = readInputs();
    const days = ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"];
    const months = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
    const selectedDateObj = new Date(E5, D5-1, C5);
    document.getElementById('moon-day').innerText = days[selectedDateObj.getDay()];
    document.getElementById('moon-date').innerText = `${C5} ${months[D5-1]} ${E5}`;
    document.getElementById('moon-location-display').innerText = document.getElementById('loc-name').value || "No Location Selected";

    let curTime, utcHour, utcMinute, utcSecond;
    if(document.getElementById('moon-manual-on').checked) {
        const hh = parseInt(document.getElementById('moon-h').value) || 0;
        const mm = parseInt(document.getElementById('moon-m').value) || 0;
        const ss = parseInt(document.getElementById('moon-s').value) || 0;
        curTime = hh + mm/60 + ss/3600;
        document.getElementById('moon-clock').innerText = format12Hour(hh, mm, ss);
        const localTotalSec = hh * 3600 + mm * 60 + ss;
        const utcTotalSec = localTotalSec - ST * 3600;
        let utcH = Math.floor(utcTotalSec / 3600) % 24;
        let utcM = Math.floor((utcTotalSec % 3600) / 60);
        let utcS = utcTotalSec % 60;
        if (utcH < 0) utcH += 24;
        utcHour = utcH; utcMinute = utcM; utcSecond = utcS;
    } else {
        const now = new Date();
        utcHour = now.getUTCHours();
        utcMinute = now.getUTCMinutes();
        utcSecond = now.getUTCSeconds();
        const localMs = now.getTime() + ST * 3600000;
        const localDate = new Date(localMs);
        const localHour = localDate.getUTCHours();
        const localMin = localDate.getUTCMinutes();
        const localSec = localDate.getUTCSeconds();
        curTime = localHour + localMin/60 + localSec/3600;
        document.getElementById('moon-clock').innerText = format12Hour(localHour, localMin, localSec);
    }

    const JD_Moon = jdFromUTCDate(E5, D5, C5, utcHour, utcMinute, utcSecond);
    const F14_DT = getDeltaT(E5);
    const JD0 = getJD0(new Date(Date.UTC(E5, D5-1, C5, 0,0,0))); // noon of the day

    // ========== Moonrise calculation (today) ==========
    // Using the exact same algorithm as in getMoonriseAlgoSteps (6 iterations)
    let dip = (58.2 / 3600) * Math.sqrt(elev);
    let t_rise = 6.0; // initial guess
    for (let iter = 0; iter < 6; iter++) {
        let JD_iter = JD0 + (t_rise - ST) / 24;
        let m = getAlmanacMoon(JD_iter, F14_DT, F11, F13);
        let localHour = ((JD_iter - 0.5) % 1) * 24;
        if (localHour < 0) localHour += 24;
        let eotm = -localHour + m.gha/15 + 12;
        if (eotm > 12) eotm -= 24;
        if (eotm < -12) eotm += 24;
        let transit = 12 + ST - F13/15 - eotm;
        let h0 = 90 + 0.56916 + m.sd - m.hp + dip;
        let cosH = (cosd(h0) - sind(F11) * sind(m.dec)) / (cosd(F11) * cosd(m.dec));
        if (Math.abs(cosH) > 1) cosH = Math.sign(cosH) * 0.9999;
        let H = acos(cosH) * (180/Math.PI) / 15;
        t_rise = transit - H;
    }
    // Normalize moonrise time and get day offset exactly as in getMoonriseAlgoSteps
    let riseTimeNorm = t_rise;
    let riseDayOffset = 0;
    while (riseTimeNorm < 0) { riseTimeNorm += 24; riseDayOffset -= 1; }
    while (riseTimeNorm >= 24) { riseTimeNorm -= 24; riseDayOffset += 1; }
    window.lastMoonriseDayOffset = riseDayOffset; // save for next moonrise

    // ========== Moonset calculation (exactly as in getMoonsetAlgoSteps) ==========
    let t_set = 18.0; // initial guess
    for (let iter = 0; iter < 6; iter++) {
        let JD_iter = JD0 + (t_set - ST) / 24;
        let m = getAlmanacMoon(JD_iter, F14_DT, F11, F13);
        let localHour = ((JD_iter - 0.5) % 1) * 24;
        if (localHour < 0) localHour += 24;
        let eotm = -localHour + m.gha/15 + 12;
        if (eotm > 12) eotm -= 24;
        if (eotm < -12) eotm += 24;
        let transit = 12 + ST - F13/15 - eotm;
        let h0 = 90 + 0.56916 + m.sd - m.hp + dip;
        let cosH = (cosd(h0) - sind(F11) * sind(m.dec)) / (cosd(F11) * cosd(m.dec));
        if (Math.abs(cosH) > 1) cosH = Math.sign(cosH) * 0.9999;
        let H = acos(cosH) * (180/Math.PI) / 15;
        t_set = transit + H;
    }
    let setTimeNorm = t_set;
    let setDayOffset = 0;
    while (setTimeNorm < 0) { setTimeNorm += 24; setDayOffset -= 1; }
    while (setTimeNorm >= 24) { setTimeNorm -= 24; setDayOffset += 1; }

    // ========== Transit calculation (exactly as in getMoonTransitAlgoSteps) ==========
    let t_transit = 12.0; // start at noon
    for (let iter = 0; iter < 6; iter++) {
        let JD_iter = JD0 + (t_transit - ST) / 24;
        let m = getAlmanacMoon(JD_iter, F14_DT, F11, F13);
        let localHour = ((JD_iter - 0.5) % 1) * 24;
        if (localHour < 0) localHour += 24;
        let eotm = -localHour + m.gha/15 + 12;
        if (eotm > 12) eotm -= 24;
        if (eotm < -12) eotm += 24;
        t_transit = 12 + ST - F13/15 - eotm;
    }
    let transitTimeNorm = t_transit;
    let transitDayOffset = 0;
    while (transitTimeNorm < 0) { transitTimeNorm += 24; transitDayOffset -= 1; }
    while (transitTimeNorm >= 24) { transitTimeNorm -= 24; transitDayOffset += 1; }

    // ========== Next Moonrise calculation (exactly as in getNextMoonriseAlgoSteps) ==========
    let JD_tomorrow = JD0 + 1;
    let t_next = 6.0;
    for (let iter = 0; iter < 6; iter++) {
        let JD_iter = JD_tomorrow + (t_next - ST) / 24;
        let m = getAlmanacMoon(JD_iter, F14_DT, F11, F13);
        let localHour = ((JD_iter - 0.5) % 1) * 24;
        if (localHour < 0) localHour += 24;
        let eotm = -localHour + m.gha/15 + 12;
        if (eotm > 12) eotm -= 24;
        if (eotm < -12) eotm += 24;
        let transit = 12 + ST - F13/15 - eotm;
        let h0 = 90 + 0.56916 + m.sd - m.hp + dip;
        let cosH = (cosd(h0) - sind(F11) * sind(m.dec)) / (cosd(F11) * cosd(m.dec));
        if (Math.abs(cosH) > 1) cosH = Math.sign(cosH) * 0.9999;
        let H = acos(cosH) * (180/Math.PI) / 15;
        t_next = transit - H;
    }
    let nextTimeNorm = t_next;
    let nextDayOffset = riseDayOffset + 1; // as per getNextMoonriseAlgoSteps
    // Normalize time WITHOUT changing dayOffset (exactly as in getNextMoonriseAlgoSteps)
    while (nextTimeNorm < 0) nextTimeNorm += 24;
    while (nextTimeNorm >= 24) nextTimeNorm -= 24;

    // ========== Helper to format time with day label ==========
    const fmtMoonTime = (t, dayOffset) => {
        if(isNaN(t)) return "--:--:--";
        let label = "Today";
        if (dayOffset === -1) label = "Yesterday";
        else if (dayOffset === 0) label = "Today";
        else if (dayOffset === 1) label = "Tomorrow";
        else if (dayOffset < -1) label = Math.abs(dayOffset) + " days ago";
        else if (dayOffset > 1) label = "In " + dayOffset + " days";
        return `
            <div class="moon-time-block">
                <div class="moon-time-text">${formatTimeAMPM(t)}</div>
                <div class="moon-day-label">(${label})</div>
            </div>
        `;
    };

    // Update the HTML elements for moon times
    document.getElementById('out-moonrise-today').innerHTML = fmtMoonTime(riseTimeNorm, riseDayOffset);
    document.getElementById('out-moonrise-next').innerHTML = fmtMoonTime(nextTimeNorm, nextDayOffset);
    document.getElementById('out-moonset').innerHTML = fmtMoonTime(setTimeNorm, setDayOffset);
    document.getElementById('out-moontransit').innerHTML = fmtMoonTime(transitTimeNorm, transitDayOffset);

    // ========== باقی Moon ڈیٹا (RA, Dec, GHA, وغیرہ) پہلے کی طرح ==========
    const m = getAlmanacMoon(JD_Moon, F14_DT, F11, F13);
    const moonAgeData = getPreciseMoonAge(JD_Moon, F14_DT);
    
    document.getElementById('out-m-age-precise').innerHTML = 
        `<div class="moon-age-display">${moonAgeData.days}d ${moonAgeData.hours}h ${moonAgeData.minutes}m ${moonAgeData.seconds}s</div>
         <div style="font-size:0.8rem; color:var(--text-muted)">${moonAgeData.percentage.toFixed(1)}% of cycle</div>`;

    let EOTM = -(curTime - ST) + m.gha/15 + 12;
    if(EOTM > 12) EOTM -= 24; else if(EOTM < -12) EOTM += 24;

    document.getElementById('out-m-ra').innerText = formatDMS(m.ra);
