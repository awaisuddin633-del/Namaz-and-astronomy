            }
            
            // Normalize t
            t = t % 24;
            if (t < 0) t += 24;
            
            // Check if moon is above horizon (considering wrap-around)
            let possible = false;
            if (!isNaN(moonrise) && !isNaN(moonset)) {
                if (moonrise < moonset) {
                    possible = (t >= moonrise - 1/3600 && t <= moonset + 1/3600);
                } else {
                    // crosses midnight
                    possible = (t >= moonrise - 1/3600 || t <= moonset + 1/3600);
                }
            } else {
                possible = false; // if no rise/set, moon is below horizon all day
            }
            
            return { time: t, possible: possible };
        }
        
        // Get Sun data at specific Julian Date for Qibla calculations
        function getSunDataForQibla(jd, year) {
            const dt = getDeltaT(year);
            RunAlmanacCalculations(jd, dt);
            Sun();
            return {
                dec: DECsun,
                eot: EOT / 60  // convert to hours
            };
        }
        
        // Get Moon data at specific Julian Date for Qibla calculations  
        function getMoonDataForQibla(jd, year, tz) {
            const dt = getDeltaT(year);
            RunAlmanacCalculations(jd, dt);
            Sun();
            Moon();
            // Calculate Moon EOT
            let localHour = ((jd - 0.5) % 1) * 24;
            if (localHour < 0) localHour += 24;
            let eotm = -localHour + GHAmoon/15 + 12;
            if (eotm > 12) eotm -= 24;
            if (eotm < -12) eotm += 24;
            return {
                dec: DECmoon,
                eot: eotm
            };
        }
        
        // Calculate E and F values for Qibla direction timing
        function calcEF(lat, A, dec) {
            let latRad = lat * dtr;
            let ARad = A * dtr;
            let decRad = dec * dtr;
            
            let tanA = Math.tan(ARad);
            let sinLat = Math.sin(latRad);
            let cosLat = Math.cos(latRad);
            let tanDec = Math.tan(decRad);
            
            let denominator = Math.sqrt(1 + Math.pow(sinLat * tanA, 2));
            let numerator = cosLat * tanA * tanDec;
            
            // Check for valid asin input
            let asinArg = numerator / denominator;
            if (Math.abs(asinArg) > 1) {
                return { valid: false, E: 0, F: 0 };
            }
            
            let E = Math.asin(asinArg) / dtr;  // Convert to degrees
            let F = Math.atan(sinLat * tanA) / dtr;  // Convert to degrees
            
            return { valid: true, E: E, F: F };
        }
        
        // Format Qibla time with Possible/Not Possible status
        function formatQiblaTime(result) {
            if (isNaN(result.time)) {
                return '<span style="color:var(--text-muted);">Not Available</span>';
            }
            
            let timeStr = formatTimeAMPM(result.time);
            let statusColor = result.possible ? 'green' : 'red';
            let statusText = result.possible ? 'Possible' : 'Not Possible';
            
            return `<div style="display: flex; flex-direction: column; align-items: flex-end;">
                <div>${timeStr}</div>
                <div style="font-size:0.75rem; color:${statusColor}; margin-top:3px;">(${statusText})</div>
            </div>`;
        }
        
