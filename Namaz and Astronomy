        const borderRight = parseFloat(computedStyle.borderRightWidth) || 0;
        const borderBottom = parseFloat(computedStyle.borderBottomWidth) || 0;
        const borderLeft = parseFloat(computedStyle.borderLeftWidth) || 0;
        const maxBorder = Math.max(borderTop, borderRight, borderBottom, borderLeft);
        const padding = maxBorder + 50;
        
        const newWidth = canvas.width + padding * 2;
        const newHeight = canvas.height + padding * 2;
        const newCanvas = document.createElement('canvas');
        newCanvas.width = newWidth;
        newCanvas.height = newHeight;
        const ctx = newCanvas.getContext('2d');
        
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, newWidth, newHeight);
        ctx.drawImage(canvas, padding, padding);
        
        if (format === 'image') {
            const link = document.createElement('a');
            link.download = `sehri-iftari-${document.getElementById('ramadan-year').value}.png`;
            link.href = newCanvas.toDataURL('image/png');
            link.click();
        } else {
            const imgData = newCanvas.toDataURL('image/png');
            const { jsPDF } = window.jspdf;
            const pdf = new jsPDF({
                orientation: newCanvas.width > newCanvas.height ? 'l' : 'p',
                unit: 'px',
                format: [newCanvas.width, newCanvas.height]
            });
            pdf.addImage(imgData, 'PNG', 0, 0, newCanvas.width, newCanvas.height);
            pdf.save(`sehri-iftari-${document.getElementById('ramadan-year').value}.pdf`);
        }
        
        // بٹن کو دوبارہ دکھائیں
        if (btn) {
            if (originalDisplay === null || originalDisplay === '') {
                btn.style.display = 'inline-block';
            } else {
                btn.style.display = originalDisplay;
            }
        }
    }).catch(err => {
        console.error('Download failed:', err);
        alert('Download failed. Check console for details.');
        if (btn) btn.style.display = originalDisplay !== null ? originalDisplay : 'inline-block';
    });
}


        // ---------- Init ----------
        window.onload = () => {
            syncSystemDate();
            initThemes();
            const locSaved = localStorage.getItem('namaz_location_data');
            if(locSaved) {
                const d = JSON.parse(locSaved);
                document.getElementById('selected-location-display').innerText = d.name || "No location selected";
                document.getElementById('loc-name').value = d.name || "";
                document.getElementById('loc-lat').value = d.lat || "";
                document.getElementById('loc-lon').value = d.lon || "";
                document.getElementById('loc-elev').value = d.elev || "";
                document.getElementById('loc-tz').value = d.tz || "";
                document.getElementById('loc-pressure').value = d.pressure || 1013;
                document.getElementById('loc-temp').value = d.temp || 15;
                if(d.tzName) locTimezone = d.tzName;
            }
            
            const savedAsr = localStorage.getItem('namaz_asr_school');
            if (savedAsr && (savedAsr === 'hanafi' || savedAsr === 'shafii')) {
                asrSchool = savedAsr;
            }
            const savedIsha = localStorage.getItem('namaz_isha_school');
            if (savedIsha && (savedIsha === 'hanafi' || savedIsha === 'shafii')) {
                ishaSchool = savedIsha;
            }
            
            if(!document.getElementById('sun-manual-on').checked) startSunTimer();
            if(!document.getElementById('moon-manual-on').checked) startMoonTimer();
            updateGMTClocks();

            setAsrSchool(asrSchool);
            setIshaSchool(ishaSchool);
            startPrayerTimer();
            calculate(); // this will call updateQiblaBasic()
        };
    </script>
