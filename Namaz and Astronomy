    let k_end = k_start + 30;
    
    for (let k = k_start; k <= k_end; k++) {
        let newmoon_tt = meanNewMoonJDE(k) + newMoonCorrection(k);
        let newmoon_ut = newmoon_tt - getDeltaT(year) / 86400;
        if (newmoon_ut >= startJD && newmoon_ut < endJD) {
            let islamic = getIslamicMonthFromNewMoon(k);
            if (islamic.name === "Ramadan") {
                let firstDayJD = newmoon_ut + 1;
                let firstDayDate = jdToDate(firstDayJD);
                return { date: firstDayDate, hijriYear: islamic.year };
            }
        }
    }
    return null;
}

function getRamadanLength(startJD) {
    // startJD رمضان کے پہلے دن کا JD ہے (جو پہلے ہی نیو مون +1 ہے)
    // اس سے پہلے والے نیو مون کی تلاش
    let jd = startJD - 1; // رمضان کے پہلے دن سے پہلے والی تاریخ
    let k = Math.floor((jd - REF_JD_NEWMOON) / SYNODIC_MONTH);
    let prev_newmoon = meanNewMoonJDE(k) + newMoonCorrection(k);
    prev_newmoon = prev_newmoon - getDeltaT(new Date(jdToDate(prev_newmoon).getUTCFullYear())) / 86400;
    // اگلا نیو مون
    let next_newmoon = meanNewMoonJDE(k+1) + newMoonCorrection(k+1);
    next_newmoon = next_newmoon - getDeltaT(new Date(jdToDate(next_newmoon).getUTCFullYear())) / 86400;
    let days = Math.round(next_newmoon - prev_newmoon);
    return days; // 29 or 30
}

function generateRamadanTimes(year) {
    // موجودہ لوکیشن کے پیرامیٹرز (نماز کے اوقات کے لیے درکار)
    let { F11, F13, ST, elev, pressure, temp } = readInputs();
    
    // مون پریڈکشن سے رمضان کا ڈیٹا حاصل کریں
    let moons = getNewMoonsForYear(year);
    let ramadanEntry = null;
    for (let m of moons) {
        if (m.monthName === "Ramadan") {
            ramadanEntry = m;
            break;
        }
    }
    
    if (!ramadanEntry) {
        // اگر رمضان نہ ملا تو پرانا طریقہ فال بیک کے طور پر استعمال کریں
        console.warn("Ramadan not found via visibility, falling back to old method.");
        let oldMethod = getFirstRamadanDate(year);
        if (!oldMethod) return null;
        let firstDay = oldMethod.date;
        let hijriYear = oldMethod.hijriYear;
        let startJD = jdFromUTCDate(firstDay.getUTCFullYear(), firstDay.getUTCMonth() + 1, firstDay.getUTCDate(), 0, 0, 0);
        let daysCount = getRamadanLength(startJD);
        let results = [];
        for (let i = 0; i < daysCount; i++) {
            let currentDate = new Date(firstDay);
            currentDate.setUTCDate(firstDay.getUTCDate() + i);
            let times = computePrayerTimes(currentDate, F11, F13, elev, ST, asrSchool, ishaSchool, pressure, temp);
            results.push({
                date: `${currentDate.getUTCDate()}-${currentDate.getUTCMonth() + 1}-${currentDate.getUTCFullYear()}`,
                sehri: formatTimeAMPM(times.fajr),
                iftari: formatTimeAMPM(times.maghrib)
            });
        }
        return { results, daysCount, hijriYear };
    }
    
    // رمضان کا ڈیٹا مون پریڈکشن سے استعمال کریں
    let hijriYear = ramadanEntry.hijriYear;
    let firstDateStr = ramadanEntry.firstDate; // مثال: "1-3-2025"
    let daysCount = ramadanEntry.days;
    
    // firstDateStr کو ڈیٹ آبجیکٹ میں بدلیں (UTC)
    let parts = firstDateStr.split('-');
    let firstDay = new Date(Date.UTC(parseInt(parts[2]), parseInt(parts[1]) - 1, parseInt(parts[0])));
    
    let results = [];
    for (let i = 0; i < daysCount; i++) {
        let currentDate = new Date(firstDay);
        currentDate.setUTCDate(firstDay.getUTCDate() + i);
        let times = computePrayerTimes(currentDate, F11, F13, elev, ST, asrSchool, ishaSchool, pressure, temp);
        results.push({
            date: `${currentDate.getUTCDate()}-${currentDate.getUTCMonth() + 1}-${currentDate.getUTCFullYear()}`,
            sehri: formatTimeAMPM(times.fajr),
            iftari: formatTimeAMPM(times.maghrib)
        });
    }
    
    return { results, daysCount, hijriYear };
}

function findExactNewMoonUT(k) {
    let approxJD_TT = meanNewMoonJDE(k) + newMoonCorrection(k);
    let approxYear = new Date(jdToDate(approxJD_TT - getDeltaT(2000) / 86400).getUTCFullYear());
    let deltaT = getDeltaT(approxYear);
    let approxJD_UT = approxJD_TT - deltaT / 86400;
    let dt = getDeltaT(approxYear);
    let exactJD_UT = findPhaseAfter(approxJD_UT - 0.5, 360, dt, 5);
    return exactJD_UT;
}

function getNewMoonsForYear(year) {
    let startJD = jdFromUTCDate(year, 1, 1, 0, 0, 0);
    let endJD = jdFromUTCDate(year + 1, 1, 1, 0, 0, 0);
    let k_start = Math.floor((startJD - REF_JD_NEWMOON) / SYNODIC_MONTH) - 2;
    let k_end = k_start + 20;
    let results = [];
    
    let { F11, F13, ST, elev } = readInputs();
    
    for (let k = k_start; k <= k_end; k++) {
        let exactJD_UT = findExactNewMoonUT(k);
        if (exactJD_UT >= startJD && exactJD_UT < endJD) {
            let localDate = jdToLocalDate(exactJD_UT, ST);
            let islamic = getIslamicMonthFromNewMoon(k);
            
            let visibleDate = getFirstDayOfIslamicMonth(exactJD_UT, F11, F13, ST, elev);
            let firstDate = new Date(visibleDate);
            firstDate.setUTCDate(visibleDate.getUTCDate() + 1);
            
            // اگلے مہینے کی پہلی تاریخ معلوم کریں
            let nextMonthFirstDate = null;
            let days = 0;
            // اگلا نیو مون (k+1) تلاش کریں
            let nextExactJD_UT = findExactNewMoonUT(k + 1);
            if (nextExactJD_UT && nextExactJD_UT < endJD + 40) { // اگلے سال تک کی حد
                let nextVisibleDate = getFirstDayOfIslamicMonth(nextExactJD_UT, F11, F13, ST, elev);
                let nextFirstDate = new Date(nextVisibleDate);
                nextFirstDate.setUTCDate(nextVisibleDate.getUTCDate() + 1);
                nextMonthFirstDate = nextFirstDate;
                
                // دنوں کی تعداد = اگلے مہینے کی پہلی تاریخ - موجودہ مہینے کی پہلی تاریخ
                let firstJD = jdFromUTCDate(firstDate.getUTCFullYear(), firstDate.getUTCMonth()+1, firstDate.getUTCDate(), 0, 0, 0);
                let nextFirstJD = jdFromUTCDate(nextFirstDate.getUTCFullYear(), nextFirstDate.getUTCMonth()+1, nextFirstDate.getUTCDate(), 0, 0, 0);
                days = Math.round(nextFirstJD - firstJD);
            } else {
                // اگر اگلا سال میں نہیں ملتا تو فرض کریں 30 دن
                days = 30;
            }
            
            results.push({
                newMoonDate: `${localDate.getUTCDate()}-${localDate.getUTCMonth()+1}-${localDate.getUTCFullYear()}`,
                newMoonTime: formatTimeOnly(localDate),
                monthName: islamic.name,
                hijriYear: islamic.year,
                visibleDate: `${visibleDate.getUTCDate()}-${visibleDate.getUTCMonth()+1}-${visibleDate.getUTCFullYear()}`,
                firstDate: `${firstDate.getUTCDate()}-${firstDate.getUTCMonth()+1}-${firstDate.getUTCFullYear()}`,
                days: days
            });
        }
    }
    return results;
}

