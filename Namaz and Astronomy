    `;
}

// Moon Azimuth 
function getMoonAzimuthSteps() {
    // ============================================================
    // STEP 1: READ INPUT VALUES (Date, Time, Location)
    // ============================================================
    let { C5, D5, E5, F11, F13, ST } = readInputs();
    let date = new Date(Date.UTC(E5, D5-1, C5, 0, 0, 0));
    let JD0 = getJD0(date);
    let dt = getDeltaT(E5);

    // Determine current local time (either manual override or system time)
    let curTime;
    if (document.getElementById('moon-manual-on').checked) {
        let hh = parseInt(document.getElementById('moon-h').value) || 0;
        let mm = parseInt(document.getElementById('moon-m').value) || 0;
        let ss = parseInt(document.getElementById('moon-s').value) || 0;
        curTime = hh + mm / 60 + ss / 3600;
    } else {
        let now = new Date();
        let localMs = now.getTime() + ST * 3600000;
        let localDate = new Date(localMs);
        curTime = localDate.getUTCHours() + localDate.getUTCMinutes() / 60 + localDate.getUTCSeconds() / 3600;
    }

    // Julian date for the current instant (UT)
    let JD = JD0 + (curTime - ST) / 24;

    // ============================================================
    // STEP 2: OBTAIN MOON'S DECLINATION, LOCAL HOUR ANGLE, AND ALTITUDE
    // ============================================================
    let moonData = getAlmanacMoon(JD, dt, F11, F13);
    let dec = moonData.dec;           // Declination in degrees
    let lha = moonData.lha;           // Local Hour Angle in degrees
    let alt = moonData.alt;           // Altitude in degrees
    let az_almanac = moonData.az;     // Azimuth from almanac (degrees)

    // ============================================================
    // STEP 3: COMPUTE AZIMUTH USING COSINE FORMULA (METHOD A)
    // ============================================================
    // Formula: cos(Az) = [ sin(δ) - sin(φ)·sin(h) ] / [ cos(φ)·cos(h) ]
    // Then Az_base = arccos(cos(Az)), and adjust quadrant based on sin(LHA)

    let sinDec = Math.sin(dec * dtr);
    let sinLat = Math.sin(F11 * dtr);
    let sinAlt = Math.sin(alt * dtr);
    let cosLat = Math.cos(F11 * dtr);
    let cosAlt = Math.cos(alt * dtr);
    let sinLHA = Math.sin(lha * dtr);

    let numerator = sinDec - sinLat * sinAlt;
    let denominator = cosLat * cosAlt;
    let cosAz = numerator / denominator;
    // Clamp to valid range [-1, 1] due to possible rounding errors
    if (cosAz > 1) cosAz = 1;
    if (cosAz < -1) cosAz = -1;

    let az_base_rad = Math.acos(cosAz);
    let az_base_deg = az_base_rad / dtr;

    // Quadrant adjustment
    let az_deg;
    if (sinLHA > 0) {
        // LHA between 0 and 180 -> object in west, azimuth = 360 - az_base
        az_deg = 360 - az_base_deg;
    } else {
        // LHA between 180 and 360 -> object in east, azimuth = az_base
        az_deg = az_base_deg;
    }
    // Normalize to 0-360 (though already in range)
    az_deg = (az_deg + 360) % 360;

    // ============================================================
    // STEP 4: GENERATE HTML OUTPUT IN THE EXACT STYLE OF THE EXAMPLE
    // ============================================================
    return `
        <p><span class="formula">Moon's Azimuth Calculation (Method A)</span></p>

        <p>Azimuth is the horizontal angle measured clockwise from north to the point on the horizon directly below the Moon.</p>

        <p>Date: ${C5}/${D5}/${E5}, Time: ${curTime.toFixed(4)} h (local), JD: <span class="value">${JD.toFixed(5)}</span></p>
        <p>Observer's Latitude: <span class="value">${F11.toFixed(4)}°</span>, Longitude: <span class="value">${F13.toFixed(4)}°</span></p>
        <p>ΔT = <span class="value">${dt.toFixed(2)} sec</span></p>
        <hr>

        <p><span class="formula">Step 1: Compute Moon's Declination (Dec), Local Hour Angle (LHA), and Altitude.</span></p>
        <p>Dec = <span class="value">${formatDMS(dec)}</span></p>
        <p>LHA = <span class="value">${formatDMS(lha)}</span></p>
        <p>Altitude = <span class="value">${formatDMS(alt)}</span></p>
        <hr>

        <p><span class="formula">Step 2: Calculate azimuth using spherical trigonometry (cosine formula).</span></p>
        <p style="margin: 8px 0;">cos(Az) = [ sin(δ) - sin(φ) × sin(h) ] / [ cos(φ) × cos(h) ]</p>

        <p style="margin-left: 20px; font-size: 0.9rem; color: var(--text-muted);">
            Where:<br>
            δ = Declination<br>
            φ = Latitude<br>
            h = Altitude
        </p>

        <div style="background: rgba(0,0,0,0.02); padding: 12px; border-radius: 8px; margin: 15px 0;">
            <table style="width:100%; border-collapse: collapse;">
                 <tr><td><strong>Latitude (φ)</strong></td><td style="text-align:right;"><span class="value">${F11.toFixed(4)}°</span></td></tr>
                 <tr><td><strong>Declination (δ)</strong></td><td style="text-align:right;"><span class="value">${dec.toFixed(4)}°</span></td></tr>
                 <tr><td><strong>Altitude (h)</strong></td><td style="text-align:right;"><span class="value">${alt.toFixed(4)}°</span></td></tr>
                 <tr><td><strong>Local Hour Angle (LHA)</strong></td><td style="text-align:right;"><span class="value">${lha.toFixed(4)}°</span></td></tr>
             </table>
        </div>

        <div style="margin: 15px 0;">
            <p><strong>1. Numerator = sin(δ) - sin(φ)·sin(h)</strong><br>
            = sin(${dec.toFixed(4)}°) - sin(${F11.toFixed(4)}°)·sin(${alt.toFixed(4)}°)<br>
            = ${sinDec.toFixed(6)} - (${sinLat.toFixed(6)} × ${sinAlt.toFixed(6)})<br>
            = ${sinDec.toFixed(6)} - ${(sinLat * sinAlt).toFixed(6)}<br>
            = <span class="value">${numerator.toFixed(6)}</span></p>

            <p><strong>2. Denominator = cos(φ)·cos(h)</strong><br>
            = cos(${F11.toFixed(4)}°)·cos(${alt.toFixed(4)}°)<br>
            = ${cosLat.toFixed(6)} × ${cosAlt.toFixed(6)}<br>
            = <span class="value">${denominator.toFixed(6)}</span></p>

            <p><strong>3. cos(Az) = Numerator / Denominator</strong><br>
            = ${numerator.toFixed(6)} / ${denominator.toFixed(6)}<br>
            = <span class="value" style="color: var(--primary);">${cosAz.toFixed(6)}</span></p>

            <p><strong>4. Az_base = arccos(cos(Az))</strong><br>
            = <span class="value">${az_base_deg.toFixed(4)}°</span></p>

            <p><strong>5. Quadrant adjustment:</strong><br>
            The value of sin(LHA) determines the correct quadrant:</p>
            <ul>
                <li><strong>If sin(LHA) > 0</strong> (i.e., LHA between 0° and 180°), the Moon is in the western half of the sky. Then the azimuth is:
                    <br>Az = 360° − Az_base = 360° − ${az_base_deg.toFixed(4)}° = <span class="value">${(360 - az_base_deg).toFixed(4)}°</span>
                </li>
                <li><strong>If sin(LHA) < 0</strong> (i.e., LHA between 180° and 360°), the Moon is in the eastern half. Then the azimuth is:
                    <br>Az = Az_base = ${az_base_deg.toFixed(4)}°
                </li>
            </ul>
            <p>Here, sin(LHA) = sin(${lha.toFixed(4)}°) = <span class="value">${sinLHA.toFixed(4)}</span>, which is <strong>${sinLHA > 0 ? 'positive' : 'negative'}</strong>.</p>
            <p>Therefore, we use the ${sinLHA > 0 ? 'first' : 'second'} rule:</p>
            <p><strong>Final Azimuth = <span class="value">${az_deg.toFixed(4)}°</span></strong></p>
        </div>

        <p style="font-size: 1.1rem; margin-top: 15px;"><strong>Final Azimuth:</strong> <span style="color: var(--primary);">${formatDMS(az_almanac)}</span></p>
        <p><i>Note: The almanac value is the definitive result; the step-by-step calculation demonstrates the underlying spherical trigonometry.</i></p>
    `;
}

