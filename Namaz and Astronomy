function getMoonPossiblePredictionSteps() {
    let { C5, D5, E5, F11, F13, ST } = readInputs();
    let date = new Date(Date.UTC(E5, D5-1, C5, 0,0,0));
    let JD0 = getJD0(date);
    let dt = getDeltaT(E5);
    
    let curTime;
    if(document.getElementById('moon-manual-on').checked) {
        let hh = parseInt(document.getElementById('moon-h').value) || 0;
        let mm = parseInt(document.getElementById('moon-m').value) || 0;
        let ss = parseInt(document.getElementById('moon-s').value) || 0;
        curTime = hh + mm/60 + ss/3600;
    } else {
        let now = new Date();
        let localMs = now.getTime() + ST * 3600000;
        let localDate = new Date(localMs);
        curTime = localDate.getUTCHours() + localDate.getUTCMinutes()/60 + localDate.getUTCSeconds()/3600;
    }
    
    let JD = JD0 + (curTime - ST) / 24;
    let moonData = getAlmanacMoon(JD, dt, F11, F13);
    let ageData = getPreciseMoonAge(JD, dt);
    let age = ageData.daysTotal;
    let alt = moonData.alt;
    let elong = Math.abs(moonData.elongation);
    
    // Yallop's q parameter calculation
    let W = age;
    let ARCV = elong;
    let q = (ARCV - (11.8371 - 6.3226 * W + 0.7319 * W * W - 0.1018 * W * W * W)) / 10;
    
    let prediction = "NON-VISIBLE";
    if (q >= 0.216) {
        prediction = "VISIBLE";
    } else if (q >= -0.016) {
        prediction = "MAY OR MAY NOT";
    } else {
        prediction = "NON-VISIBLE";
    }
    
    // اگر چاند افق سے نیچے ہو تو نظر نہیں آ سکتا
    if (alt <= 0) {
        prediction = "NON-VISIBLE";
    }
    
    return `
        <div class="calc-steps">
            <p><span class="formula">Moon Visibility Prediction (Yallop's q Criterion)</span></p>
            <p>Yallop's q parameter is a scientifically accepted method for predicting lunar crescent visibility.</p>
            <p>Date: ${C5}/${D5}/${E5}, Time: ${curTime.toFixed(4)} h (local), JD: <span class="value">${JD.toFixed(5)}</span></p>
            <hr>
            <p><span class="formula">Input Parameters:</span></p>
            <ul>
                <li>Moon altitude at sunset: <span class="value">${alt.toFixed(2)}°</span></li>
                <li>Elongation from Sun (ARCV): <span class="value">${elong.toFixed(2)}°</span></li>
                <li>Moon age: <span class="value">${age.toFixed(4)} days</span></li>
            </ul>
            
            <p><span class="formula">Yallop's Formula:</span></p>
            <p style="font-family: monospace;">
                q = (ARCV - (11.8371 - 6.3226×W + 0.7319×W² - 0.1018×W³)) / 10
            </p>
            <p>Where W = Moon age in days, ARCV = elongation in degrees.</p>
            
            <p><span class="formula">Step-by-Step Calculation:</span></p>
            <p>W = ${age.toFixed(4)} days<br>
            ARCV = ${elong.toFixed(4)}°</p>
            <p>Compute: 11.8371 - 6.3226×W + 0.7319×W² - 0.1018×W³</p>
            <p>= 11.8371 - ${(6.3226 * W).toFixed(4)} + ${(0.7319 * W * W).toFixed(4)} - ${(0.1018 * W * W * W).toFixed(4)}</p>
            <p>= <span class="value">${(11.8371 - 6.3226 * W + 0.7319 * W * W - 0.1018 * W * W * W).toFixed(4)}</span></p>
            <p>Then q = (${elong.toFixed(4)} - ${(11.8371 - 6.3226 * W + 0.7319 * W * W - 0.1018 * W * W * W).toFixed(4)}) / 10</p>
            <p>= <span class="value">${q.toFixed(4)}</span></p>
            
            <p><span class="formula">Classification:</span></p>
            <ul>
                <li>q ≥ 0.216 → <strong>VISIBLE</strong></li>
                <li>0.216 > q ≥ -0.016 → <strong>MAY OR MAY NOT</strong></li>
                <li>q < -0.016 → <strong>NON-VISIBLE</strong></li>
            </ul>
            <p>q = ${q.toFixed(4)} → <span class="value">${prediction}</span></p>
            ${alt <= 0 ? "<p><strong>Note:</strong> Moon is below horizon, so definitely NON-VISIBLE.</p>" : ""}
            
            <p><span class="formula">Final Prediction:</span> <strong>${prediction}</strong></p>
            <div style="text-align: right; margin-top: 15px;">
                <button class="copy-btn" onclick="copyCalculationText(this)">Copy</button>
            </div>
        </div>
    `;
}
