                        // ∆T (Delta T) calculation steps
        function getDeltaTAlgoSteps() {
            let { C5, D5, E5 } = readInputs();
            let year = E5;
            let dt = getDeltaT(year);
            
            // Delta T formula based on year range
            let formula = "";
            let cv = (year - 2000) / 100;
            
            if (year < 1900) {
                formula = "ΔT = -13.95389181 + 32 × ((year-1800)/100)²";
            } else if (year < 1950) {
                formula = "ΔT = 26.04610819 + 32 × ((year-1800)/100)²";
            } else if (year < 1977) {
                formula = "ΔT = 27.64610819 + 0.67×cv + 0.11×cv², where cv = (year-2000)/100";
            } else if (year < 1999) {
