        function computeDhuhaTime(fajrTime, maghribTime) {
            return (fajrTime + maghribTime) / 2;
        }

        function computeAsrTime(date, lat, lon, tz, elev, zuhrTime, asrFactor, pressure, temp) {
            let JD0 = getJD0(date);
