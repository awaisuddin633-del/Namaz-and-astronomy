        eot: EOT/60
    };
}

        function getAlmanacMoon(jd, deltaT, lat, lon) {
    RunAlmanacCalculations(jd, deltaT);
    Sun();
    Moon();
    let gha = GHAmoon;
    let lha = norm_360_deg(gha + lon);
    let sha = 360 - RAmoon;
    let latRad = lat * dtr;
    let decRad = DECmoon * dtr;
    let lhaRad = lha * dtr;
    let sinAlt = sin(latRad)*sin(decRad) + cos(latRad)*cos(decRad)*cos(lhaRad);
    let altRad = asin(sinAlt);
    let alt = altRad / dtr;

    // CORRECT azimuth calculation
    let sinLHA = sin(lhaRad);
    let cosDec = cos(decRad);
    let cosLat = cos(latRad);
    let numerator = -sinLHA * cosDec * cosLat;
    let denominator = sin(decRad) - sin(latRad) * sin(altRad);
    let az_rad = atan2(numerator, denominator);
    let az_deg = az_rad * (180 / PI);
    let az = (az_deg + 360) % 360;

    // ... باقی پہلے کی طرح
    let raDiff = RAmoon - RAsun;
    while (raDiff > 180) raDiff -= 360;
    while (raDiff <= -180) raDiff += 360;
    let sinDecM = sind(DECmoon);
    let sinDecS = sind(DECsun);
    let cosDecM = cosd(DECmoon);
    let cosDecS = cosd(DECsun);
    let cosRaDiff = cosd(raDiff);
    let elongationRad = Math.acos(sinDecM * sinDecS + cosDecM * cosDecS * cosRaDiff);
    let elongationDeg = elongationRad / dtr;
    let elongation = Math.sign(raDiff) * elongationDeg;

    return {
        dec: DECmoon, ra: RAmoon, ghaArise: GHAAtrue, gha: GHAmoon,
        lha: lha, sha: sha, alt: alt, az: az,
        sd: SDmoon/3600, hp: HPmoon/3600,
        dist: dEM,
        phase: k,
        elongation: elongation,
        sunRA: RAsun,
        sunDec: DECsun
    };
}

        function getPreciseMoonAge(jd, deltaT) {
    // Helper to compute elongation at a given JD (UT)
    function getElong(jd_ut) {
        RunAlmanacCalculations(jd_ut, deltaT);
        Sun();
        Moon();
        let elong = lambdaMapp - lambdaSun;
        elong = ((elong % 360) + 360) % 360;
        return elong;
    }

    const SYNODIC_MONTH_MEAN = 29.530588853;
    const REF_JD_NEWMOON = 2451550.09765;

    // Step 1: Find approximate new moon before current JD
    let jd_tt = jd + deltaT / 86400.0;
    let k = Math.floor((jd_tt - REF_JD_NEWMOON) / SYNODIC_MONTH_MEAN);
    let jde0 = REF_JD_NEWMOON + SYNODIC_MONTH_MEAN * k;
    while (jde0 > jd_tt) { k--; jde0 = REF_JD_NEWMOON + SYNODIC_MONTH_MEAN * k; }

    // Step 2: Find exact last new moon
    let lo = jde0 - 1.0, hi = jde0 + 1.0;
    let flo = getElong(lo - deltaT / 86400.0);
    let fhi = getElong(hi - deltaT / 86400.0);
    if (flo > 270) flo -= 360;
    if (fhi > 270) fhi -= 360;

    let iter = 0;
    while (flo * fhi > 0 && iter < 20) {
        lo -= 1; hi += 1;
        flo = getElong(lo - deltaT / 86400.0);
        fhi = getElong(hi - deltaT / 86400.0);
        if (flo > 270) flo -= 360;
        if (fhi > 270) fhi -= 360;
        iter++;
    }

    let lastNewMoonJD_tt;
    if (flo * fhi > 0) {
        lastNewMoonJD_tt = jde0;
    } else {
        for (let i = 0; i < 60; i++) {
            let mid = (lo + hi) / 2;
            let fmid = getElong(mid - deltaT / 86400.0);
            if (fmid > 270) fmid -= 360;
            if (Math.abs(fmid) < 1e-8) { lastNewMoonJD_tt = mid; break; }
            if (fmid * flo < 0) { hi = mid; fhi = fmid; }
            else { lo = mid; flo = fmid; }
        }
        if (!lastNewMoonJD_tt) lastNewMoonJD_tt = (lo + hi) / 2;
    }

    // Step 3: Find next new moon (add one synodic month approximate, then refine)
    let nextGuess = lastNewMoonJD_tt + SYNODIC_MONTH_MEAN;
    lo = nextGuess - 1.0;
    hi = nextGuess + 1.0;
    flo = getElong(lo - deltaT / 86400.0);
    fhi = getElong(hi - deltaT / 86400.0);
    if (flo > 270) flo -= 360;
    if (fhi > 270) fhi -= 360;

    iter = 0;
    while (flo * fhi > 0 && iter < 20) {
        lo -= 1; hi += 1;
        flo = getElong(lo - deltaT / 86400.0);
        fhi = getElong(hi - deltaT / 86400.0);
        if (flo > 270) flo -= 360;
        if (fhi > 270) fhi -= 360;
        iter++;
    }

    let nextNewMoonJD_tt;
    if (flo * fhi > 0) {
        nextNewMoonJD_tt = nextGuess;
    } else {
        for (let i = 0; i < 60; i++) {
            let mid = (lo + hi) / 2;
            let fmid = getElong(mid - deltaT / 86400.0);
            if (fmid > 270) fmid -= 360;
            if (Math.abs(fmid) < 1e-8) { nextNewMoonJD_tt = mid; break; }
            if (fmid * flo < 0) { hi = mid; fhi = fmid; }
            else { lo = mid; flo = fmid; }
        }
        if (!nextNewMoonJD_tt) nextNewMoonJD_tt = (lo + hi) / 2;
    }

    // Age = current TT - last new moon TT
    let ageDays = jd_tt - lastNewMoonJD_tt;
    // Normalize to [0, SYNODIC_MONTH_MEAN) (should already be, but for safety)
    ageDays = ((ageDays % SYNODIC_MONTH_MEAN) + SYNODIC_MONTH_MEAN) % SYNODIC_MONTH_MEAN;

    const days = Math.floor(ageDays);
    const rem = (ageDays - days) * 24;
    const hours = Math.floor(rem);
    const rem2 = (rem - hours) * 60;
    const minutes = Math.floor(rem2);
    const seconds = Math.floor((rem2 - minutes) * 60);
    const percentage = (ageDays / SYNODIC_MONTH_MEAN) * 100;
    const currentElong = getElong(jd);

    // Actual synodic duration for this cycle (in days)
    const actualCycleDuration = nextNewMoonJD_tt - lastNewMoonJD_tt;

    return {
        daysTotal: ageDays,
        days: days,
        hours: hours,
        minutes: minutes,
        seconds: seconds,
        percentage: percentage,
        degrees: currentElong,
        lastNewMoonJD: lastNewMoonJD_tt - deltaT / 86400.0,   // convert to UT
        nextNewMoonJD: nextNewMoonJD_tt - deltaT / 86400.0,   // convert to UT
        cycleDuration: actualCycleDuration
    };
}

