function getMoonRAAlgoSteps() {
    // ============================================================
    // STEP 1: READ INPUT VALUES (Date, Time, Location)
    // ============================================================
    let { C5, D5, E5, F11, F13, ST } = readInputs();
    let date = new Date(Date.UTC(E5, D5-1, C5, 0, 0, 0));
    let JD0 = getJD0(date);
    let dt = getDeltaT(E5);

    // Determine current local time (either manual override or system time)
    let curTime;
    if (document.getElementById('moon-manual-on').checked) {
        let hh = parseInt(document.getElementById('moon-h').value) || 0;
        let mm = parseInt(document.getElementById('moon-m').value) || 0;
        let ss = parseInt(document.getElementById('moon-s').value) || 0;
        curTime = hh + mm / 60 + ss / 3600;
    } else {
        let now = new Date();
        let localMs = now.getTime() + ST * 3600000;
        let localDate = new Date(localMs);
        curTime = localDate.getUTCHours() + localDate.getUTCMinutes() / 60 + localDate.getUTCSeconds() / 3600;
    }

    // Julian date for the current instant (UT)
    let JD = JD0 + (curTime - ST) / 24;

    // ============================================================
    // STEP 2: OBTAIN MOON'S ECLIPTIC COORDINATES AND OBLIQUITY
    // ============================================================
    RunAlmanacCalculations(JD, dt);
    Sun();   // updates eps, etc.
    Moon();  // updates lambdaMapp, betaM

    let lambda = lambdaMapp;   // Moon's ecliptic longitude in degrees
    let beta = betaM;          // Moon's ecliptic latitude in degrees
    let epsilon = eps;         // true obliquity of the ecliptic (including nutation)

    // ============================================================
    // STEP 3: CONVERSION FROM ECLIPTIC TO EQUATORIAL COORDINATES
    // ============================================================
    // Formula: RA = atan2( sin(λ)·cos(ε) - tan(β)·sin(ε) , cos(λ) )
    // All calculations use degree values internally converted to radians.

    let sinLambda = Math.sin(lambda * dtr);
    let cosLambda = Math.cos(lambda * dtr);
    let tanBeta = Math.tan(beta * dtr);
    let cosEps = Math.cos(epsilon * dtr);
    let sinEps = Math.sin(epsilon * dtr);

    let numerator = sinLambda * cosEps - tanBeta * sinEps;
    let denominator = cosLambda;

    let ra_rad = Math.atan2(numerator, denominator);
    let ra_deg_raw = ra_rad / dtr;  // range -180 to 180

    // Normalize to 0-360°
    let ra_deg = ra_deg_raw;
    if (ra_deg < 0) ra_deg += 360;

    // Also obtain the final RA from the almanac for comparison
    let moonData = getAlmanacMoon(JD, dt, F11, F13);
    let ra_almanac = moonData.ra; // degrees
    let ra_hours = ra_almanac / 15; // hours

    // ============================================================
    // STEP 4: GENERATE HTML OUTPUT WITH DETAILS (NO 3D, NO EMOJIS)
    // ============================================================
    return `
        <p><span class="formula">Moon's Right Ascension (RA)</span></p>

        <p>Right Ascension (RA) is the angular distance measured eastward along the celestial equator from the vernal equinox to the hour circle of the celestial body. It is usually expressed in hours, minutes, and seconds (1 hour = 15°).</p>

        <h4>Input Values at This Moment</h4>
