        function findPhaseAfter(startJD, targetAngle, deltaT, maxDays = 40) {
    let target = targetAngle;
    if (target === 0) target = 360;   // New Moon

    for (let i = 1; i <= maxDays; i++) {
        let jdPrev = startJD + i - 1;
        let jdCurr = startJD + i;
        let anglePrev = phaseAngleAtJD(jdPrev, deltaT);
        let angleCurr = phaseAngleAtJD(jdCurr, deltaT);

        // Adjust for wrap-around when target is 360°
        let aPrev = anglePrev;
        let aCurr = angleCurr;
        if (target === 360) {
            // Bring angles > 270 into negative range so that crossing 0 becomes detectable
            if (aPrev > 270) aPrev -= 360;
            if (aCurr > 270) aCurr -= 360;
            // The target in normalized coordinates is 0
            let normTarget = 0;
            if ((aPrev <= normTarget && normTarget <= aCurr) ||
                (aCurr <= normTarget && normTarget <= aPrev)) {
                // Found crossing
                let lo = jdPrev, hi = jdCurr;
                let flo = aPrev, fhi = aCurr;
                for (let j = 0; j < 60; j++) {
                    let mid = (lo + hi) / 2;
                    let fmid = phaseAngleAtJD(mid, deltaT);
                    if (fmid > 270) fmid -= 360;
                    if (Math.abs(fmid - normTarget) < 1e-8) return mid;
                    if (fmid < normTarget) {
                        lo = mid;
                        flo = fmid;
                    } else {
                        hi = mid;
                        fhi = fmid;
                    }
                }
                return (lo + hi) / 2;
            }
        } else {
            // For other targets (90, 180, 270) no wrap needed
            if ((aPrev <= target && target <= aCurr) ||
                (aCurr <= target && target <= aPrev)) {
                let lo = jdPrev, hi = jdCurr;
                let flo = aPrev, fhi = aCurr;
                for (let j = 0; j < 60; j++) {
                    let mid = (lo + hi) / 2;
                    let fmid = phaseAngleAtJD(mid, deltaT);
                    if (Math.abs(fmid - target) < 1e-8) return mid;
                    if (fmid < target) {
                        lo = mid;
                        flo = fmid;
                    } else {
                        hi = mid;
                        fhi = fmid;
                    }
                }
                return (lo + hi) / 2;
            }
        }
    }
    return NaN;
}

